---
import { features } from '../config/content';

// Minimal inline icon set keyed by the `icon` field in content.ts.
const paths: Record<string, string> = {
  bolt: 'M13 2 3 14h7l-1 8 10-12h-7l1-8Z',
  chart: 'M4 20V10M10 20V4M16 20v-6M22 20H2',
  shield: 'M12 3l7 3v6c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3Z',
  users: 'M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm13 10v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75',
  plug: 'M9 2v6m6-6v6M6 8h12v3a6 6 0 0 1-12 0V8Zm6 9v5',
  lock: 'M5 11h14v10H5V11Zm2 0V7a5 5 0 0 1 10 0v4',
};
---
<section id="features" class="scroll-mt-20 border-t border-slate-100 bg-slate-50/50 py-20 dark:border-slate-800 dark:bg-slate-900/30">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white" style="font-family: var(--font-display)">
        {features.title}
      </h2>
      <p class="mt-4 text-lg text-slate-600 dark:text-slate-300">{features.subtitle}</p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.items.map((f) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-6 transition hover:shadow-md dark:border-slate-800 dark:bg-slate-900">
          <span class="inline-grid h-11 w-11 place-items-center rounded-xl bg-[color:color-mix(in_srgb,var(--color-brand)_12%,transparent)] text-brand">
            <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d={paths[f.icon] ?? paths.bolt} />
            </svg>
          </span>
          <h3 class="mt-4 text-lg font-semibold text-slate-900 dark:text-white">{f.title}</h3>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
