---
import { site } from '../config/site';
import Logo from './Logo.astro';
import ThemeToggle from './ThemeToggle.astro';
---
<header class="sticky top-0 z-40 border-b border-slate-200/70 bg-white/80 backdrop-blur dark:border-slate-800/70 dark:bg-slate-950/80">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6" aria-label="Main">
    <Logo />

    <div class="hidden items-center gap-8 md:flex">
      {site.nav.map((item) => (
        <a href={item.href} class="text-sm font-medium text-slate-600 transition hover:text-slate-900 dark:text-slate-300 dark:hover:text-white">
          {item.label}
        </a>
      ))}
    </div>

    <div class="flex items-center gap-2">
      <ThemeToggle />
      <a
        href={site.headerCta.href}
        class="hidden rounded-md bg-brand px-4 py-2 text-sm font-semibold text-[color:var(--color-brand-fg)] transition hover:bg-brand-hover sm:inline-block"
      >
        {site.headerCta.label}
      </a>
      <button
        id="menu-toggle"
        type="button"
        class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-slate-200 text-slate-600 md:hidden dark:border-slate-700 dark:text-slate-300"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 7h16M4 12h16M4 17h16" />
        </svg>
      </button>
    </div>
  </nav>

  <div id="mobile-menu" class="hidden border-t border-slate-200 px-4 py-3 md:hidden dark:border-slate-800">
    <ul class="flex flex-col gap-1">
      {site.nav.map((item) => (
        <li>
          <a href={item.href} class="block rounded-md px-2 py-2 text-sm font-medium text-slate-700 hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800">
            {item.label}
          </a>
        </li>
      ))}
      <li>
        <a href={site.headerCta.href} class="mt-1 block rounded-md bg-brand px-3 py-2 text-center text-sm font-semibold text-[color:var(--color-brand-fg)]">
          {site.headerCta.label}
        </a>
      </li>
    </ul>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById('menu-toggle');
    var menu = document.getElementById('mobile-menu');
    if (!btn || !menu) return;
    btn.addEventListener('click', function () {
      var open = menu.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', String(open));
      btn.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    });
  })();
</script>
