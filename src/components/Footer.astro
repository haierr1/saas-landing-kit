---
import { site } from '../config/site';
import Logo from './Logo.astro';

const year = new Date().getFullYear();
---
<footer class="border-t border-slate-200 bg-slate-50 dark:border-slate-800 dark:bg-slate-900/50">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <div class="max-w-xs">
        <Logo />
        <p class="mt-3 text-sm text-slate-500 dark:text-slate-400">{site.tagline}.</p>
        <ul class="mt-4 flex gap-4">
          {site.social.map((s) => (
            <li>
              <a href={s.href} class="text-sm text-slate-500 hover:text-slate-900 dark:text-slate-400 dark:hover:text-white" rel="noopener">
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <nav aria-label="Footer">
        <h2 class="text-xs font-semibold uppercase tracking-wider text-slate-400">Get in touch</h2>
        <ul class="mt-3 space-y-2">
          <li><a href="/#features" class="text-sm text-slate-600 hover:text-slate-900 dark:text-slate-300 dark:hover:text-white">Features</a></li>
          <li><a href={`mailto:${site.contactEmail}`} class="text-sm text-slate-600 hover:text-slate-900 dark:text-slate-300 dark:hover:text-white">{site.contactEmail}</a></li>
        </ul>
      </nav>
    </div>

    <div class="mt-10 border-t border-slate-200 pt-6 text-sm text-slate-500 dark:border-slate-800 dark:text-slate-400">
      © {year} {site.name}. All rights reserved.
    </div>
  </div>
</footer>
