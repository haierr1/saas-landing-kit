---
import { testimonials } from '../config/content';
---
<section class="py-20">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <h2 class="text-center text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl dark:text-white" style="font-family: var(--font-display)">
      {testimonials.title}
    </h2>
    <div class="mt-14 grid gap-6 lg:grid-cols-3">
      {testimonials.items.map((t) => (
        <figure class="flex flex-col rounded-2xl border border-slate-200 bg-white p-6 dark:border-slate-800 dark:bg-slate-900">
          <div class="flex gap-0.5 text-brand" aria-hidden="true">
            {Array.from({ length: 5 }).map(() => (
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d="m12 2 3 6.5 7 .6-5.3 4.6 1.6 6.8L12 17l-6 3.5 1.6-6.8L2 9.1l7-.6L12 2Z" /></svg>
            ))}
          </div>
          <blockquote class="mt-4 flex-1 text-slate-700 dark:text-slate-200">"{t.quote}"</blockquote>
          <figcaption class="mt-4 flex items-center gap-3">
            <span class="grid h-10 w-10 place-items-center rounded-full bg-[color:color-mix(in_srgb,var(--color-brand)_15%,transparent)] text-sm font-semibold text-brand" aria-hidden="true">
              {t.name.split(' ').map((n) => n[0]).join('')}
            </span>
            <span>
              <span class="block text-sm font-semibold text-slate-900 dark:text-white">{t.name}</span>
              <span class="block text-sm text-slate-500 dark:text-slate-400">{t.role}</span>
            </span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
