---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page not found">
  <section class="mx-auto flex max-w-xl flex-col items-center px-4 py-32 text-center sm:px-6">
    <p class="text-6xl font-bold text-brand" style="font-family: var(--font-display)">404</p>
    <h1 class="mt-4 text-2xl font-bold tracking-tight text-slate-900 dark:text-white">This page went missing</h1>
    <p class="mt-3 text-slate-600 dark:text-slate-300">
      The link may be broken or the page may have moved. Let's get you back on track.
    </p>
    <div class="mt-8 flex gap-3">
      <a href="/" class="rounded-md bg-brand px-5 py-2.5 text-sm font-semibold text-[color:var(--color-brand-fg)] transition hover:bg-brand-hover">
        Back home
      </a>
    </div>
  </section>
</BaseLayout>
